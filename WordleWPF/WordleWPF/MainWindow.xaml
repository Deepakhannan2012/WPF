<Window x:Class="WordleWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WordleWPF"
        mc:Ignorable="d"
         Title="UI" SizeToContent="WidthAndHeight">
    <StackPanel Margin="10" Orientation="Vertical" ButtonBase.Click="Button_Click">
        <StackPanel.Resources>
            <Style TargetType="StackPanel">
                <Setter Property="Orientation" Value="Horizontal"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Height" Value="25"/>
                <Setter Property="Width" Value="20"/>
                <Setter Property="Margin" Value="0.5,0,0.5,1"/>
            </Style>
        </StackPanel.Resources>
        <ItemsControl ItemsSource="{Binding GridData}">

            <!-- Rows -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>

                    <!-- Each row -->
                    <ItemsControl ItemsSource="{Binding}">

                        <!-- Columns -->
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <TextBox Text="{Binding Value, Mode=TwoWay}"
                                 Width="50"
                                 Height="50"
                                 TextAlignment="Center"
                                 FontSize="20"/>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
        <TextBlock x:Name="Result" Margin="0,0,0,5" Height="10" HorizontalAlignment="Center"/>
        <StackPanel>
            <Button Content="Q"/>
            <Button Content="W"/>
            <Button Content="E"/>
            <Button Content="R"/>
            <Button Content="T"/>
            <Button Content="Y"/>
            <Button Content="U"/>
            <Button Content="I"/>
            <Button Content="O"/>
            <Button Content="P"/>
        </StackPanel>
        <StackPanel>
            <Button Content="A"/>
            <Button Content="S"/>
            <Button Content="D"/>
            <Button Content="F"/>
            <Button Content="G"/>
            <Button Content="H"/>
            <Button Content="J"/>
            <Button Content="K"/>
            <Button Content="L"/>
        </StackPanel>
        <StackPanel>
            <Button Content="Enter" Width="24.5" FontSize="9"/>
            <Button Content="Z"/>
            <Button Content="X"/>
            <Button Content="C"/>
            <Button Content="V"/>
            <Button Content="B"/>
            <Button Content="N"/>
            <Button Content="M"/>
            <Button Content="&#x232B;" Width="24.5"/>
        </StackPanel>
    </StackPanel>
</Window>
